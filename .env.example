# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Analytics Configuration (optional)
# Get this from your Google Analytics 4 property
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Instructions:
# 1. Copy this file to .env

# Paddle (payment) configuration - v2 API
# Get these values from your Paddle dashboard: https://sandbox-vendors.paddle.com/ (sandbox) or https://vendors.paddle.com/ (live)

# Client-side token for Paddle.js initialization
# Create this in: Paddle > Developer tools > Authentication > Create a client-side token
# Sandbox tokens start with test_
VITE_PADDLE_CLIENT_TOKEN=test_7d279f61a3499fed520f7cd8c08

# Price ID for the Pro plan subscription
# Create or get the price ID from: Paddle > Products > [Your Product] > Prices
# Example format: pri_01gsz8ntc6z7npqqp6j4ys0w1w
VITE_PADDLE_PRICE_ID=pri_01gsz8ntc6z7npqqp6j4ys0w1w

# Sandbox mode for local testing (set to 'true' to enable)
# When enabled, Paddle will use the sandbox environment instead of production
VITE_PADDLE_SANDBOX=true